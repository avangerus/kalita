{
  "entity": "Expense",
  "statuses": [
    "Draft",
    "ForApproval",
    "Approved",
    "ToPayment",
    "Paid",
    "Rejected"
  ],
  "steps": [
    {
      "name": "Создание расхода",
      "type": "Input",
      "status": "Draft",
      "actors": ["role:Accountant"],
      "fieldsRequired": ["Amount"]
    },
    {
      "name": "Согласование финдиректором",
      "type": "Approve",
      "status": "ForApproval",
      "actors": ["role:FinancialDirector"]
    },
    {
      "name": "Утверждение директором",
      "type": "Approve",
      "status": "ForApproval",
      "actors": ["role:Director"]
    }
  ],
  "transitions": [
    { "from": "Draft", "to": "ForApproval", "condition": "FieldsFilled" },
    { "from": "ForApproval", "to": "Approved", "condition": "AllApprovalsDone" },
    { "from": "Approved", "to": "ToPayment" },
    { "from": "ToPayment", "to": "Paid", "condition": "PaymentConfirmed" },
    { "from": "Any", "to": "Rejected", "condition": "RejectedByAny" }
  ]
}
