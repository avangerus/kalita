{
  "type": "Estimate",
  "displayName": "Смета",
  "initialStatus": "draft",
  "statuses": [
    {
      "code": "draft",
      "displayName": "Черновик",
      "stage": "Создание",
      "actions": [
        {
          "code": "submit",
          "displayName": "Отправить на согласование",
          "roles": ["Author"],
          "toStatus": "DirectorApproval"
        }
      ],
      "editRights": ["Author"],
      "viewRights": ["Author", "Admin"],
      "uiMask": "edit_mode"
    },
    {
      "code": "DirectorApproval",
      "displayName": "Согласование директором",
      "stage": "Согласование",
      "actions": [
        {
          "code": "approve",
          "displayName": "Согласовать",
          "roles": ["Director"],
          "toStatus": "ParallelApproval"
        },
        {
          "code": "reject",
          "displayName": "Отклонить",
          "roles": ["Director"],
          "toStatus": "Rejected",
          "requiresComment": true
        }
      ],
      "editRights": [],
      "viewRights": ["Author", "Director", "Admin"],
      "uiMask": "approval_mode",
      "modifiers": ["highlight"]
    },
    {
      "code": "ParallelApproval",
      "displayName": "Параллельное согласование",
      "stage": "Согласование",
      "actions": [
        {
          "code": "approve",
          "displayName": "Согласовать",
          "roles": ["Lawyer", "CFO"],
          "toStatus": "AccountantApproval",
          "allMustApprove": true
        },
        {
          "code": "reject",
          "displayName": "Отклонить",
          "roles": ["Lawyer", "CFO"],
          "toStatus": "Rejected",
          "requiresComment": true
        }
      ],
      "editRights": [],
      "viewRights": ["Lawyer", "CFO", "Director", "Author", "Admin"],
      "uiMask": "parallel_approval_mode"
    },
    {
      "code": "AccountantApproval",
      "displayName": "Согласование бухгалтером",
      "stage": "Финансы",
      "actions": [
        {
          "code": "approve",
          "displayName": "Согласовать",
          "roles": ["Accountant"],
          "toStatus": "ToPayment"
        }
      ],
      "conditions": [
        {
          "if": "amount > 500000",
          "then": "show"
        },
        {
          "if": "amount <= 500000",
          "then": "skip"
        }
      ],
      "editRights": [],
      "viewRights": ["Accountant", "Director", "Author", "Admin"],
      "uiMask": "finance_approval_mode"
    },
    {
      "code": "ToPayment",
      "displayName": "К оплате",
      "stage": "Завершение",
      "actions": [
        {
          "code": "pay",
          "displayName": "Оплатить",
          "roles": ["Treasurer"],
          "toStatus": "Paid"
        }
      ],
      "editRights": [],
      "viewRights": ["Treasurer", "Accountant", "Director", "Author", "Admin"],
      "uiMask": "payment_mode"
    },
    {
      "code": "Paid",
      "displayName": "Оплачено",
      "stage": "Завершение",
      "actions": [],
      "editRights": [],
      "viewRights": ["Author", "Admin", "Director"],
      "uiMask": "readonly"
    },
    {
      "code": "Rejected",
      "displayName": "Отклонено",
      "stage": "Завершение",
      "actions": [],
      "editRights": [],
      "viewRights": ["Author", "Admin", "Director"],
      "uiMask": "readonly"
    }
  ],
  "globalActions": [
    {
      "code": "reject",
      "displayName": "Отклонить",
      "roles": ["Director", "CFO", "Lawyer", "Accountant", "Treasurer"],
      "toStatus": "Rejected",
      "requiresComment": true,
      "fromStatuses": ["Any"]
    }
  ]
}
