# Copy to .env and fill in. Then: docker compose up --build
POSTGRES_PASSWORD=change-me-strong
KALITA_BOOTSTRAP_SECRET=change-me-very-strong-shared-secret

# Where your embedding + chat models live (LM Studio, vLLM, Ollama, OpenAI-compatible).
# From inside compose, localhost is the container — use the host gateway or a LAN IP.
KV_LM=http://host.docker.internal:1234
KV_EMBED_MODEL=text-embedding-nomic-embed-text-v1.5
KV_CHAT_MODEL=openai/gpt-oss-20b
